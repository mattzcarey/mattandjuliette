{
  "name": "mattandjuliette",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply mattandjuliette-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply mattandjuliette-db --remote",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-router": "^1.144.0",
    "@tanstack/router-plugin": "^1.132.0",
    "@vitejs/plugin-react": "^5.0.4",
    "drizzle-orm": "^0.45.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.0.6",
    "vite": "^7.3.0",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.35.0",
    "@tanstack/router-cli": "^1.166.40",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.54.0"
  }
}
